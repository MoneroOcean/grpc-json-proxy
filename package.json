{
  "name": "grpc-json-proxy",
  "version": "1.0.0",
  "description": "Small JSON-RPC to gRPC proxy for Tari node and wallet protos with quiet daemon-style status output.",
  "private": true,
  "type": "module",
  "license": "BSD-3-Clause",
  "engines": {
    "node": ">=22.9.0",
    "npm": ">=11.10.0"
  },
  "scripts": {
    "start": "node ./grpc-json-proxy.js",
    "pretest": "npm run lint",
    "test": "node --test tests/*.js",
    "check": "node --check ./grpc-json-proxy.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@grpc/grpc-js": "1.14.3",
    "@grpc/proto-loader": "0.8.0"
  },
  "overrides": {
    "protobufjs": "7.5.6"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "globals": "^17.6.0"
  }
}
